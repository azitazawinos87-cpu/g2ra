{
  "name": "ghtun",
  "build": {
    "dockerfile": "./Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },

  "postStartCommand": "chmod +x /workspaces/g2ray/watch.sh /workspaces/g2ray/start_services.sh /workspaces/g2ray/usage-agent.sh /workspaces/g2ray/install-traffic-agent.sh",

  "postAttachCommand": {
    "public": "gh codespace ports visibility 443:public -c ${CODESPACE_NAME:-$(hostname)} || true",
    "xray": "pkill -f '/usr/local/bin/xray' 2>/dev/null || true; nohup sudo /usr/local/bin/xray -c /etc/config.json > /tmp/xray.out 2>&1 &",
    "watchdog": "pkill -f '/workspaces/g2ray/watch.sh' 2>/dev/null || true; nohup /workspaces/g2ray/watch.sh > /tmp/watchdog.out 2>&1 &",
    "traffic": "TRAFFIC_API_URL='http://141.11.18.186:3010/api/traffic/push' TRAFFIC_TOKEN='change_me_traffic_token' TRAFFIC_INTERVAL=10 XRAY_INBOUND_TAG='vless-in' TRAFFIC_WORKSPACE='${CODESPACE_NAME:-$(hostname)}' /workspaces/g2ray/install-traffic-agent.sh"
  },

  "portsAttributes": {
    "443": {
      "label": "xray",
      "protocol": "http",
      "onAutoForward": "silent"
    }
  },
  "forwardPorts": [443],
  "hostRequirements": {
    "cpus": 2
  }
}
